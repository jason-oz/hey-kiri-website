{
  "name": "hey-kiri",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx @11ty/eleventy --serve --port=8080\" \"npx @tailwindcss/cli -i src/assets/css/styles.css -o _site/assets/css/styles.css --watch\"",
    "build": "npx @tailwindcss/cli -i src/assets/css/styles.css -o _site/assets/css/styles.css --minify && npx @11ty/eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@quasibit/eleventy-plugin-sitemap": "^2.2.0"
  }
}
