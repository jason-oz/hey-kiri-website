---
layout: layouts/base.njk
title: "Contact | HeyKIRI — Book a Discovery Call"
description: "Ready to talk about your brand? Book a discovery call with HeyKIRI or get in touch by phone, text, or email."
permalink: /contact/
breadcrumb: Contact
---

<section class="pt-28 pb-20 px-6">
  <div class="mx-auto max-w-4xl">
    <p class="text-sm uppercase tracking-widest text-primary mb-4 font-medium">Get in Touch</p>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Let's talk about your brand</h1>
    <p class="text-lg text-muted-foreground mb-12">Book a discovery call — no pressure, no pitch. Just an honest conversation about where your brand is and where it could be.</p>

    <div class="grid md:grid-cols-2 gap-12">
      {# Contact details #}
      <div class="space-y-8">
        <div>
          <p class="text-sm text-muted-foreground uppercase tracking-wider mb-2">Phone / Text</p>
          <a href="tel:{{ site.phone }}" class="block text-lg font-semibold hover:text-primary transition-colors min-h-[44px] py-2">{{ site.phoneDisplay }}</a>
        </div>
        <div>
          <p class="text-sm text-muted-foreground uppercase tracking-wider mb-2">Email</p>
          <a href="mailto:{{ site.email }}" class="block text-lg font-semibold hover:text-primary transition-colors min-h-[44px] py-2">{{ site.email }}</a>
        </div>

        {# Social links #}
        <div>
          <p class="text-sm text-muted-foreground uppercase tracking-wider mb-3">Connect</p>
          <div class="flex gap-4">
            {% if site.social.instagram %}
            <a href="{{ site.social.instagram }}" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            </a>
            {% endif %}
            {% if site.social.facebook %}
            <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            {% endif %}
            {% if site.social.linkedin %}
            <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            {% endif %}
          </div>
        </div>

        {# Discovery call booking embed #}
        <div>
          <p class="text-sm text-muted-foreground uppercase tracking-wider mb-3">Book a Call</p>
          <div class="bg-secondary rounded-xl p-6 border border-border">
            <p class="text-sm font-semibold mb-2">Book a Discovery Call</p>
            <p class="text-muted-foreground text-sm mb-4">Free, no-obligation — pick a time that works for you.</p>
            <!-- REPLACE: Embed Kiri's booking calendar widget here (Calendly, Cal.com, HighLevel, etc.) -->
            <div class="bg-background/50 rounded-lg p-4 border border-border text-center">
              <p class="text-muted-foreground text-sm">Booking calendar embed goes here</p>
            </div>
          </div>
        </div>
      </div>

      {# Contact form #}
      <div>
        <h2 class="text-xl font-bold mb-6">Send a message</h2>
        <form id="contact-form" class="space-y-5" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium mb-2">Name <span class="text-primary">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name"
              class="w-full bg-secondary border border-border rounded-lg px-4 py-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors min-h-[44px]"
              placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-2">Email <span class="text-primary">*</span></label>
            <input type="email" id="email" name="email" required autocomplete="email"
              class="w-full bg-secondary border border-border rounded-lg px-4 py-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors min-h-[44px]"
              placeholder="you@example.com" />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium mb-2">What's this about?</label>
            <input type="text" id="subject" name="subject" autocomplete="off"
              class="w-full bg-secondary border border-border rounded-lg px-4 py-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors min-h-[44px]"
              placeholder="e.g. New brand, rebrand, just curious" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-2">Message <span class="text-primary">*</span></label>
            <textarea id="message" name="message" required rows="5"
              class="w-full bg-secondary border border-border rounded-lg px-4 py-3 text-foreground placeholder:text-muted-foreground focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors resize-y"
              placeholder="Tell me a bit about your brand and what you're looking for…"></textarea>
          </div>

          <div id="form-error" class="hidden text-sm text-destructive bg-destructive/10 border border-destructive/30 rounded-lg px-4 py-3" role="alert"></div>

          <button type="submit" id="submit-btn"
            class="w-full bg-primary text-primary-foreground font-semibold rounded-lg px-6 py-4 hover:brightness-110 transition-all min-h-[44px] flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed">
            <span id="submit-label">Send Message</span>
            <svg id="submit-spinner" class="hidden animate-spin" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
          </button>
        </form>

        <div id="form-success" class="hidden bg-primary/10 border border-primary/30 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">&#10003;</div>
          <h3 class="font-bold text-lg mb-2">Message sent!</h3>
          <p class="text-muted-foreground text-sm">Thanks for reaching out. I'll get back to you within 1–2 business days.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% block scripts %}
<script>
(function () {
  var form = document.getElementById('contact-form');
  var successEl = document.getElementById('form-success');
  var errorEl = document.getElementById('form-error');
  var btn = document.getElementById('submit-btn');
  var label = document.getElementById('submit-label');
  var spinner = document.getElementById('submit-spinner');

  if (!form) return;

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    errorEl.classList.add('hidden');

    var name = form.name.value.trim();
    var email = form.email.value.trim();
    var message = form.message.value.trim();

    if (!name || !email || !message) {
      errorEl.textContent = 'Please fill in all required fields.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    label.textContent = 'Sending…';
    spinner.classList.remove('hidden');

    try {
      var res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name,
          email: email,
          subject: form.subject ? form.subject.value.trim() : '',
          message: message
        })
      });
      var data = await res.json();
      if (res.ok) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        errorEl.textContent = data.error || 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please check your connection and try again.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      label.textContent = 'Send Message';
      spinner.classList.add('hidden');
    }
  });
})();
</script>
{% endblock %}
