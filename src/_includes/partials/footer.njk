<footer class="bg-surface py-10" data-nosnippet>
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-6">
      <div class="flex items-center gap-1">
        <span class="font-heading font-semibold text-base text-secondary-foreground/80 tracking-tight">Hey</span><span class="font-heading font-semibold text-base text-primary tracking-tight">KIRI</span>
      </div>
      <div class="flex flex-wrap items-center gap-6 text-sm text-secondary-foreground/60">
        {% for link in site.navLinks %}
        <a href="{{ link.url }}" class="hover:text-secondary-foreground transition-colors">{{ link.label }}</a>
        {% endfor %}
        <a href="/privacy" class="hover:text-secondary-foreground transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-secondary-foreground transition-colors">Terms</a>
      </div>
    </div>
    {% if site.social %}
    <div class="flex justify-center gap-5 mb-6">
      {% if site.social.instagram %}
      <a href="{{ site.social.instagram }}" target="_blank" rel="noopener noreferrer" class="text-secondary-foreground/60 hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
      </a>
      {% endif %}
      {% if site.social.facebook %}
      <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer" class="text-secondary-foreground/60 hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      {% endif %}
      {% if site.social.linkedin %}
      <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer" class="text-secondary-foreground/60 hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
      {% endif %}
      {% if site.social.tiktok %}
      <a href="{{ site.social.tiktok }}" target="_blank" rel="noopener noreferrer" class="text-secondary-foreground/60 hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13v-3.5a6.37 6.37 0 0 0-.88-.07A6.34 6.34 0 0 0 3.15 15.3a6.34 6.34 0 0 0 10.86 4.48V13a8.28 8.28 0 0 0 5.58 2.16v-3.45a4.85 4.85 0 0 1-2.83-1.02z"/></svg>
      </a>
      {% endif %}
      {% if site.social.youtube %}
      <a href="{{ site.social.youtube }}" target="_blank" rel="noopener noreferrer" class="text-secondary-foreground/60 hover:text-primary transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center" aria-label="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
      </a>
      {% endif %}
    </div>
    {% endif %}
    <p class="text-center text-xs text-secondary-foreground/40">&copy; {{ "" | year }} {{ site.author }}. All rights reserved. Website by <a href="https://highcountry.digital" class="hover:text-secondary-foreground/60 transition-colors">High Country Digital</a>.</p>
  </div>
</footer>
